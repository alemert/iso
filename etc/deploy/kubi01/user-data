#cloud-config
autoinstall:
  version: 1
  shutdown: poweroff # Shutdown the system after installation is complete
  locale: en_US.UTF-8
  keyboard:
    layout: de
    variant: ""
  # Password login here is intended for local console access only.
  identity:
    hostname: kubi01
    username: ubuntu
    password: '$6$/a6Tqfm2Ecsg9Ipo$UbPgXpRBQW8GJLJvCEziemU7samaDU8hMaCoWQpONgtn1yMnT3etHJ99KKw0RZppt0LfRQiGl0gXcsUqImmLn1'
  grub:
    reorder_uefi: true # Prefer booting the installed disk entry after autoinstall
  storage:
    config:
      # Primary install disk using GPT for UEFI: hosts EFI, /boot, and LVM partitions.
      - id: disk-sda
        type: disk
        ptable: gpt
        path: /dev/sda
        wipe: superblock-recursive
      # Disk layout summary: GPT + UEFI uses separate boot-related entries on purpose:
      # part-efi/fs-efi/mnt-efi provide the firmware ESP at /boot/efi (FAT32),
      # while part-boot/fs-boot/mnt-boot provide Linux /boot (ext4) for kernels/initramfs;
      # the remaining space (part-lvm) is used for root/var/home logical volumes.

      # EFI System Partition (ESP) for UEFI firmware and GRUB boot files.
      - id: part-efi
        type: partition
        device: disk-sda
        size: 512M
        flag: boot
        grub_device: true
      # Dedicated /boot partition for kernel and initramfs outside LVM.
      - id: part-boot
        type: partition
        device: disk-sda
        size: 1G
      # Create LVM volume group vg_sys from the remaining disk partition.
      # Remaining disk space is reserved for LVM volumes.
      - id: part-lvm
        type: partition
        device: disk-sda
        size: -1
      # Format the EFI partition as FAT32 (required for UEFI boot).
      - id: fs-efi
        type: format
        volume: part-efi
        fstype: fat32
      # Mount the EFI partition to the standard UEFI path.
      - id: mnt-efi
        type: mount
        device: fs-efi
        path: /boot/efi
      # Format the dedicated /boot partition.
      - id: fs-boot
        type: format
        volume: part-boot
        fstype: ext4
      # Mount /boot where kernels and initramfs are stored.
      - id: mnt-boot
        type: mount
        device: fs-boot
        path: /boot
      # LVM volume group aggregating space from part-lvm.
      - id: vg_sys
        type: lvm_volgroup
        name: vg_sys
        devices: [part-lvm]
      - id: lv-root
        type: lvm_partition
        name: lv_root
        volgroup: vg_sys
        size: 8G
      - id: lv-var
        type: lvm_partition
        name: lv_var
        volgroup: vg_sys
        size: 4G
      - id: lv-home
        type: lvm_partition
        name: lv_home
        volgroup: vg_sys
        size: 1G
      - id: fs-root
        type: format
        volume: lv-root
        fstype: ext4
      - id: fs-var
        type: format
        volume: lv-var
        fstype: ext4
      - id: fs-home
        type: format
        volume: lv-home
        fstype: ext4
      - id: mnt-root
        type: mount
        device: fs-root
        path: /
      - id: mnt-var
        type: mount
        device: fs-var
        path: /var
      - id: mnt-home
        type: mount
        device: fs-home
        path: /home
  # Extra packages installed during autoinstall.
  packages:
    - ksh
  # SSH server configuration and authorized access keys.
  ssh:
    install-server: true
    enabled-by-default: true
    authorized-keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINfSQ+TlXJtasYD4fhuja7tZu7PqiOQ4FR+G2Zc3TUYw ales@lpfunk29
  # Post-install maintenance commands executed inside the target system.
  late-commands:
    - curtin in-target --target=/target -- apt-get update
    - curtin in-target --target=/target -- DEBIAN_FRONTEND=noninteractive apt-get -y upgrade
