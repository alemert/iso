#cloud-config
autoinstall:
  version: 1
  shutdown: poweroff # Shutdown the system after installation is complete
  locale: en_US.UTF-8
  keyboard:
    layout: de
    variant: ""
  # Password login here is intended for local console access only.
  identity:
    hostname: kubi02
    username: ubuntu
    password: '$6$/a6Tqfm2Ecsg9Ipo$UbPgXpRBQW8GJLJvCEziemU7samaDU8hMaCoWQpONgtn1yMnT3etHJ99KKw0RZppt0LfRQiGl0gXcsUqImmLn1'
  grub:
    reorder_uefi: false # Prefer booting the installed disk entry after autoinstall
  storage:
    config:
      - id: disk-sda
        type: disk
        ptable: gpt
        path: /dev/sda
        wipe: superblock-recursive
        grub_device: true
      - id: part-bios
        type: partition
        device: disk-sda
        size: 1M
        flag: bios_grub
      - id: part-boot
        type: partition
        device: disk-install
        size: 1G
      - id: part-lvm
        type: partition
        device: disk-install
        size: -1
      - id: fs-boot
        type: format
        volume: part-boot
        fstype: ext4
      - id: mnt-boot
        type: mount
        device: fs-boot
        path: /boot
      - id: vg_sys
        type: lvm_volgroup
        name: vg_sys
        devices: [part-lvm]
      - id: lv-root
        type: lvm_partition
        name: lv_root
        volgroup: vg_sys
        size: 8G
      - id: lv-var
        type: lvm_partition
        name: lv_var
        volgroup: vg_sys
        size: 4G
      - id: lv-home
        type: lvm_partition
        name: lv_home
        volgroup: vg_sys
        size: 1G
      - id: fs-root
        type: format
        volume: lv-root
        fstype: ext4
      - id: fs-var
        type: format
        volume: lv-var
        fstype: ext4
      - id: fs-home
        type: format
        volume: lv-home
        fstype: ext4
      - id: mnt-root
        type: mount
        device: fs-root
        path: /
      - id: mnt-var
        type: mount
        device: fs-var
        path: /var
      - id: mnt-home
        type: mount
        device: fs-home
        path: /home
  # Extra packages installed during autoinstall.
  packages:
    - ksh
  # SSH server configuration and authorized access keys.
  ssh:
    install-server: true
    enabled-by-default: true
    authorized-keys:
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINfSQ+TlXJtasYD4fhuja7tZu7PqiOQ4FR+G2Zc3TUYw ales@lpfunk29
  # Post-install maintenance commands executed inside the target system.
  late-commands:
    - curtin in-target --target=/target -- apt-get update
    - curtin in-target --target=/target -- env DEBIAN_FRONTEND=noninteractive apt-get -y upgrade
  network:
    version: 2
    ethernets:
      all-eth:
        match:
          name: "*"
        dhcp4: true
        dhcp4-overrides:
          send-hostname: true
          hostname: kubi02
